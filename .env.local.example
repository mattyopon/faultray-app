# ── Supabase (required) ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-side admin key — never expose with a NEXT_PUBLIC_ prefix
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Site ─────────────────────────────────────────────────────────────
# Canonical origin; used for CSRF Origin allowlist + CORS headers
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── FaultRay simulation API ──────────────────────────────────────────
# Python engine URL. Leave empty to use the local mock.
NEXT_PUBLIC_FAULTRAY_API_URL=
NEXT_PUBLIC_API_URL=

# ── Stripe (optional — billing disabled without these) ───────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Comma-separated price IDs mapped to each plan tier
STRIPE_STARTER_PRICE_IDS=price_...
STRIPE_PRO_PRICE_IDS=price_...
STRIPE_BUSINESS_PRICE_IDS=price_...

# ── Cron endpoints (/api/cron/*) ─────────────────────────────────────
# Bearer secret required by trial-expiry / trial-reminders crons
CRON_SECRET=
# Optional comma-separated IP allowlist for cron callers
CRON_ALLOWED_IPS=

# ── Email (optional — transactional email via Resend) ────────────────
RESEND_API_KEY=

# ── Admin ────────────────────────────────────────────────────────────
# Comma-separated emails allowed to view /admin (server-side only)
ADMIN_EMAILS=

# ── Rate limiting (optional — distributed backend) ───────────────────
# Requires `npm install @upstash/ratelimit @upstash/redis` to opt in;
# falls back to the in-memory limiter when unset.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Security (optional) ──────────────────────────────────────────────
# AES-256-GCM key for src/lib/crypto.ts (32 bytes, base64)
ENCRYPTION_KEY=
# Staging IP allowlist enforced by src/proxy.ts (unset = no restriction)
ALLOWED_IPS=

# ── Analytics / monitoring (optional) ────────────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_HOTJAR_ID=
NEXT_PUBLIC_SENTRY_DSN=
