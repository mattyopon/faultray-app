{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/apm",
      "destination": "/apm"
    },
    {
      "source": "/api/apm/:path*",
      "destination": "/api/apm"
    },
    {
      "source": "/api/risk",
      "destination": "/api/reports"
    },
    {
      "source": "/api/health",
      "destination": "/api/chat"
    },
    {
      "source": "/api/governance",
      "destination": "/api/compliance"
    }
  ]
}
