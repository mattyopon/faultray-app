{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/apm/:path*",
      "destination": "/api/apm"
    },
    {
      "source": "/api/risk",
      "destination": "/api/reports"
    }
  ]
}
